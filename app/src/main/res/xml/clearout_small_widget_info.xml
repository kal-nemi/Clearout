<?xml version="1.0" encoding="utf-8"?>
<!--
    Small Widget (2x1): Shows cleared storage percentage + quick launch button.
    minWidth/minHeight chosen to fit in a 2x1 home screen cell.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="50dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:updatePeriodMillis="1800000"
    android:widgetCategory="home_screen"
    android:description="@string/widget_small_description"
    android:previewLayout="@layout/widget_small_preview"
    android:resizeMode="horizontal|vertical"
    android:initialLayout="@layout/widget_small_preview" />
