<resources>
    <style name="Theme.ClearOut" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.ClearOut.Main</item>
        <item name="windowSplashScreenBackground">#1A1410</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">#FF5C1A</item>
    </style>

    <!-- The real app theme applied after splash exits -->
    <style name="Theme.ClearOut.Main" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
